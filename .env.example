# Copy to .env and fill secrets. Never commit .env.

SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=

SECRET_KEY=use-a-long-random-string-in-production
ALGORITHM=HS256
# Master spec: 15-minute access JWTs (refresh via POST /auth/refresh).
ACCESS_TOKEN_EXPIRE_MINUTES=15
SOCKET_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_DAYS=7

# AES-256-GCM for name, profile photo URL, message body, file paths at rest (optional in dev).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=

PORT=8000
NODE_ENV=development

# Guest mode (optional): AUTH_DISABLED=1 skips JWT and uses GUEST_USER_ID. Leave unset for normal ConvoHub login.
AUTH_DISABLED=
GUEST_USER_ID=1

# If NODE_ENV=production but you use http://localhost (no TLS), set true so auth cookies are stored.
ALLOW_INSECURE_COOKIES=true
# Or force secure cookies on HTTPS deploys: COOKIE_SECURE=true

# Rate limits (per IP, per 15 minutes). Auth limit applies to POST only (GET /auth/session is excluded).
RATE_LIMIT_API_MAX=800
# Default: 5000 dev / 300 prod if unset
RATE_LIMIT_AUTH_MAX=
